# GitHub API Configuration
GITHUB_TOKEN=
GITHUB_REPO_OWNER=harpertoken
GITHUB_REPO_NAME=harper

# Supabase Auth Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional verification credentials
# Used by npm run check:app for Supabase preference access and write-route checks.
DIFF_SUPABASE_ACCESS_TOKEN=
DIFF_GITHUB_PROVIDER_TOKEN=
DIFF_POST_COMMENT_PR_NUMBER=
DIFF_POST_COMMENT_BODY=
DIFF_REQUIRE_AUTH_CHECKS=0

# Used by npm run check:e2e for authenticated browser flows.
DIFF_E2E_SESSION_FILE=/tmp/diff-session.json
DIFF_E2E_GITHUB_LOGIN=
